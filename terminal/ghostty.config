# Theme
#theme = iTerm2 Smoooooth
#theme = ayu
#theme = TokyoNight
theme = Github Dark

# Font
font-family = SF Mono
font-size = 15
adjust-cell-height = 10%

# Window Padding
window-padding-x = 10
window-padding-y = 10
window-padding-balance = true

# Native macOS tab bar integrated into the title bar
macos-titlebar-style = tabs

# Block cursor instead of the default bar
cursor-style = block
cursor-style-blink = false

# Copies selected text directly to system clipboard
copy-on-select = clipboard

# Never prompt when closing a tab with a running process
confirm-close-surface = false

# Tab navigation with Cmd+Left / Cmd+Right
keybind = super+right=next_tab
keybind = super+left=previous_tab
